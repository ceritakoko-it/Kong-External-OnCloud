# Dev Portal OpenAPI generation values.
#
# This file is intentionally consumed only by pipelines/dev-portal.yml.
# Keep real credentials, real tokens, NRIC, customer data, and production keys out of this file.
#
# Request body keys use this format:
# DP_REQUEST_BODY_<METHOD>_<PUBLIC_PATH>
#
# The public path is uppercased and non-alphanumeric characters become underscores.
# Example:
#   POST /api/token -> DP_REQUEST_BODY_POST_API_TOKEN
#
# If a request body key is missing or blank, the generated OpenAPI operation has no predefined request body.
#
# Query parameter keys use this format:
# DP_QUERY_PARAMS_<METHOD>_<PUBLIC_PATH>=requiredParam*,optionalParam

DEVPORTAL_TITLE=Kong Konnect External APIs (Dev OnCloud)
DEVPORTAL_SERVER_URL=https://dev-connect.kaotim.my
DEVPORTAL_SERVER_DESCRIPTION=External Kaotim API Dev Server
DEVPORTAL_DESCRIPTION=External services exposed through Kong Gateway. Call /api/token first to obtain an access token, then reuse Authorization: Bearer <access_token> for protected APIs.

DP_TAG_DESCRIPTION_coreApi=Core API endpoints for family, motor, and customer profile flows.
DP_TAG_DESCRIPTION_CORE_API=Core API endpoints for family, motor, and customer profile flows.
DP_TAG_DESCRIPTION_generalServices=General services endpoints for CP ID and motor renewal link flows.
DP_TAG_DESCRIPTION_Token=OAuth token endpoint.

DP_CONTENT_TYPE_POST_API_TOKEN=application/x-www-form-urlencoded
DP_REQUEST_BODY_POST_API_TOKEN={"grant_type":"client_credentials","client_id":"your-client-id","client_secret":"your-client-secret"}

DP_REQUEST_BODY_POST_CORE_API_FAMILY_DOWNLOAD={"policyNo":"<policy-no>","documentType":"<document-type>"}
DP_REQUEST_BODY_POST_CORE_API_MOTOR_CERTIFICATES_DOWNLOAD_CAR={"cover_note_no":"<cover-note-no>","language":"BM"}
DP_REQUEST_BODY_POST_CORE_API_MOTOR_CERTIFICATES_DOWNLOAD_MOTORCYCLE={"cover_note_no":"<cover-note-no>","language":"BM"}
DP_REQUEST_BODY_POST_CORE_API_MOTOR_E_RECEIPT_DOWNLOAD={"e_certificate_no":"<e-certificate-no>","payment_reference_no":"<payment-reference-no>","masked_card":"","vehicle_type":"car"}

DP_QUERY_PARAMS_GET_CORE_API_2_FAMILY_CERTIFICATE_DETAILS=e_certificate_no*
DP_QUERY_PARAMS_GET_CORE_API_2_MOTOR_CERTIFICATE_DETAILS=e_certificate_no*

DP_REQUEST_BODY_POST_GENERAL_SERVICES_CREATE_CP_ID={"userNric":"<nric>","userDob":"YYYY-MM-DD","userEmail":"user@example.com","userMobile":"<mobile>","userName":"<name>","userNricType":"N","eCertNo":"<e-cert-no>"}
DP_REQUEST_BODY_POST_GENERAL_SERVICES_MOTOR_DECRYPT_RENEWAL_LINK={"link":"<renewal-link>"}
DP_REQUEST_BODY_POST_GENERAL_SERVICES_MOTOR_GENERATE_RENEWAL_LINK={"product":"motor","identificationNumber":"<identification-number>","vehRegNo":"<vehicle-registration-no>"}
